{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "First Light Mod Manager",
  "version": "0.2.0",
  "identifier": "com.flmm.manager",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "007: First Light Mod Manager",
        "width": 960,
        "height": 620,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
